{
    "schemaVersion": 1,
    "id": "msm",
    "version": "${version}",
    "name": "MySecretMods",
    "description": "Fabric 1.21.8 mod that prevents servers from detecting your mods.",
    "authors": [],
    "contact": {},
    "license": "MIT",
    "icon": "assets/msm/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "de.ole101.msm.client.MySecretModsClient"
        ],
        "main": [
            "de.ole101.msm.MySecretMods"
        ]
    },
    "mixins": [
        "msm.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${loader_version}",
        "fabric-language-kotlin": ">=${kotlin_loader_version}",
        "fabric": "*",
        "minecraft": "${minecraft_version}"
    }
}
